# 아래 항목을 실제 값으로 채운 후 파일명을 .env로 변경하세요

# 티스토리 로그인 (카카오 계정)
TISTORY_KAKAO_EMAIL=your_kakao_email@gmail.com
TISTORY_KAKAO_PASSWORD=your_kakao_password
TISTORY_BLOG_NAME=your_blog_name

# Notion
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (썸네일 자동생성용, 없으면 썸네일 생략됨)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 쿠팡 파트너스 (선택사항)
COUPANG_PARTNER_ID=your_email@gmail.com

# Pexels (본문 이미지 - 무료, 없으면 DALL-E로 자동 대체)
# https://www.pexels.com/api/ 에서 발급
PEXELS_API_KEY=
